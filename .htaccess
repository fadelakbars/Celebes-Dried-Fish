<IfModule mod_headers.c>
    # Enforce HTTPS connections
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Prevent MIME sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Prevent Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Control Referrer Information
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Restrict Device Features (Permissions)
    Header set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
    
    # Hide PHP and Server Tech Information
    Header unset X-Powered-By
    Header unset Server
    
    # Content Security Policy (CSP)
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://app.midtrans.com https://app.sandbox.midtrans.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://app.midtrans.com https://app.sandbox.midtrans.com; frame-src 'self' https://app.midtrans.com https://app.sandbox.midtrans.com; object-src 'none'; base-uri 'self';"
</IfModule>
